# GitHub Models (LLM)
GITHUB_TOKEN=your_github_token_here
LLM_MODEL=openai/gpt-4.1
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference

# Embeddings — HuggingFace local (no key needed, model downloads automatically)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Pinecone (Vector Store)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=roadmaps
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Cloudinary (PDF Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Security (Admin API Key)
ADMIN_API_KEY=your_strong_random_secret_key_here

# RAG tuning
GENERATED_CACHE_DIR=/data/generated
SIMILARITY_THRESHOLD=0.4
TOP_K_RESULTS=8

# API
DEBUG=false
